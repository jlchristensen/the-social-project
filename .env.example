# Kit (ConvertKit) — Email Newsletter
# Get your API key: Kit Dashboard → Settings → Developer → API
# Get your Form ID: Kit Dashboard → Grow → Landing Pages & Forms → click your form → the number in the URL
KIT_API_KEY=your_kit_api_key_here
KIT_FORM_ID=your_kit_form_id_here

# Supabase — Auth & Database
# Create a project at https://supabase.com → Settings → API
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
